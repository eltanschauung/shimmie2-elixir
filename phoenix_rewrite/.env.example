# Phoenix runtime
PHX_SERVER=true
PHX_HOST=example.com
PORT=4001
SECRET_KEY_BASE=replace_with_mix_phx_gen_secret

# Database (required in production unless SHIMMIE_LEGACY_DSN can be converted)
DATABASE_URL=ecto://user:pass@127.0.0.1/shimmie_phx_prod

# Legacy compatibility paths
SHIMMIE_LEGACY_ROOT=/path/to/shimmie2
SHIMMIE_ASSETS_DIR=/path/to/shimmie2/assets
SHIMMIE_LEGACY_CONFIG_PATH=/path/to/shimmie2/data/config/shimmie.conf.php

# Optional overrides
# SHIMMIE_LEGACY_DSN=sqlite:data/shimmie.sqlite
# SHIMMIE_DATABASE_URL=ecto://user:pass@127.0.0.1/shimmie
